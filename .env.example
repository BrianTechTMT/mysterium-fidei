# Mysterium Fidei — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local — it is in .gitignore

# Claude API — powers Servus AI
ANTHROPIC_API_KEY=your_claude_api_key_here

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/mysterium_fidei

# API server URL
API_URL=http://localhost:3001

# This prefix makes the variable available in the browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# Divinum Officium — self-hosted Docker (EF Office texts)
DIVINUM_OFFICIUM_URL=http://localhost:8080

# Environment
NODE_ENV=development